{
  "name": "@henosis/renderer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "henosis-render": "./dist/render.js",
    "henosis-gate": "./dist/gate.js",
    "henosis-inspect": "./dist/inspect.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "render": "node dist/render.js",
    "gate": "node dist/gate.js",
    "test": "vitest run && tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@henosis/core": "workspace:^",
    "smol-toml": "^1.3.4",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.23.0",
    "vitest": "^3.2.4"
  }
}
